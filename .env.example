# Local development configuration for scripts/deploy.sh.
# Copy this file to .env and fill in your own values. .env is gitignored.

# Required: IP or hostname of your HAOS instance.
HA_HOST=homeassistant.local

# Optional: SSH port (defaults to 22).
# The official SSH & Web Terminal addon uses 22222.
HA_PORT=22

# Optional: SSH user (defaults to root).
HA_USER=root

# Optional: IP of a Sinilink XY-WFTX device for manual protocol testing
# (e.g. via `python3 scripts/test_protocol_live.py $SINILINK_HOST`).
# Not used by the HA integration itself.
SINILINK_HOST=
